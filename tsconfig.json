{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/temp-types",
    "moduleResolution": "Bundler",
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "conf.env.d.ts"],
  "exclude": ["node_modules/**/*", "dist", "src/tests"]
}
