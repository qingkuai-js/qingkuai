{
  "name": "qingkuai",
  "license": "MIT",
  "author": "lgq",
  "type": "module",
  "version": "1.0.19",
  "engines": {
    "node": ">=14"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/runtime/index.js",
      "require": "./dist/cjs/runtime/index.cjs",
      "types": "./dist/types/runtime/index.d.ts"
    },
    "./internal": {
      "import": "./dist/esm/runtime/internal.js",
      "require": "./dist/cjs/runtime/internal.cjs",
      "types": "./dist/types/runtime/internal.d.ts"
    },
    "./compiler": {
      "import": "./dist/esm/compiler/index.js",
      "require": "./dist/cjs/compiler/index.cjs",
      "types": "./dist/types/compiler/index.d.ts"
    }
  },
  "scripts": {
    "test": "vitest",
    "dev": "rollup -c -w",
    "build": "rimraf dist && tsc && rollup -c && rimraf dist/temp-types"
  },
  "dependencies": {
    "@babel/parser": "^7.25.8",
    "@jridgewell/sourcemap-codec": "^1.5.0"
  },
  "devDependencies": {
    "@babel/types": "^7.25.8",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.16.11",
    "fs-extra": "^11.2.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.24.0",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-esbuild": "^6.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.2"
  },
  "description": "A lighteight(Qing) and fast(Kuai) front end framework, it will make you development work easier(QingKuai)"
}
