{
  "name": "qingkuai",
  "license": "MIT",
  "author": "lgq",
  "type": "module",
  "version": "1.0.81",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qingkuai-js/qingkuai.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/runtime/index.d.ts",
      "import": "./dist/esm/runtime/index.js",
      "require": "./dist/cjs/runtime/index.cjs"
    },
    "./internal": {
      "import": "./dist/esm/runtime/internal.js",
      "require": "./dist/cjs/runtime/internal.cjs"
    },
    "./compiler": {
      "types": "./dist/types/compiler/index.d.ts",
      "import": "./dist/esm/compiler/index.js",
      "require": "./dist/cjs/compiler/index.cjs"
    },
    "./language-service": {
      "types": "./dist/types/language-service/qingkuai.d.ts"
    }
  },
  "scripts": {
    "lint": "eslint",
    "prepare": "husky",
    "dev": "rollup -c -w",
    "bundle": "rollup -c",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test:units": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:e2e": "npm run bundle && playwright test",
    "test:e2e-badge": "tsx scripts/e2e-badge.ts",
    "test": "npm run test:units && npm run test:e2e",
    "test:e2e-quick": "playwright test --project=chromium-debug",
    "test:e2e-prod": "PROD_ONLY=1 npm run bundle && playwright test",
    "test:e2e-serve": "npm run bundle && PLAYWRIGHT_PORT=34173 tsx tests/e2e/server.ts",
    "build": "rimraf dist && npm run build-types && npm run bundle",
    "build-types": "npx tsc && tsx scripts/build-types.ts && rimraf dist/temp-types",
    "postpublish": "curl -X PUT 'https://registry-direct.npmmirror.com/-/package/qingkuai/syncs'"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml,qk}": "prettier --write"
  },
  "dependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.9",
    "@playwright/test": "^1.60.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.0",
    "fs-extra": "^11.3.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "rollup-plugin-esbuild": "^6.2.1",
    "tsx": "^4.22.2",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "esbuild": ">=0.28.1",
      "typescript": ">=6.0.3"
    }
  },
  "keywords": [
    "ui",
    "framework",
    "reactive",
    "compiler",
    "templates",
    "component",
    "typescript",
    "performance"
  ],
  "description": "A lighteight(Qing) and fast(Kuai) front end framework, it will make you development work easier(QingKuai)."
}
