{
  "name": "qingkuai",
  "license": "MIT",
  "author": "lgq",
  "type": "module",
  "version": "1.0.61",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/runtime/index.d.ts",
      "import": "./dist/esm/runtime/index.js",
      "require": "./dist/cjs/runtime/index.cjs"
    },
    "./internal": {
      "import": "./dist/esm/runtime/internal.js",
      "require": "./dist/cjs/runtime/internal.cjs"
    },
    "./compiler": {
      "types": "./dist/types/compiler/index.d.ts",
      "import": "./dist/esm/compiler/index.js",
      "require": "./dist/cjs/compiler/index.cjs"
    },
    "./language-service": {
      "types": "./dist/types/language-service/qingkuai.d.ts"
    }
  },
  "scripts": {
      "lint": "eslint",
      "dev": "rollup -c -w",
      "bundle": "rollup -c",
      "test:units": "vitest --run",
      "typecheck": "tsc --noEmit",
    "test:e2e": "npm run bundle && playwright test",
    "test:e2e-prod": "PROD_ONLY=1 npm run bundle && playwright test",
    "test:e2e-serve": "npm run bundle && PLAYWRIGHT_PORT=34173 tsx tests/e2e/server.ts",
    "build": "rimraf dist && npm run build-types && npm run bundle",
    "build-types": "npx tsc && tsx scripts/build-types.ts && rimraf dist/temp-types",
    "postpublish": "curl -X PUT 'https://registry-direct.npmmirror.com/-/package/qingkuai/syncs'"
  },
  "dependencies": {
    "@babel/parser": "^7.28.0",
    "@jridgewell/sourcemap-codec": "^1.5.5"
  },
  "devDependencies": {
    "@babel/types": "^7.28.1",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.57.7",
    "@playwright/test": "^1.58.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.2.0",
    "eslint": "^10.1.0",
    "fs-extra": "^11.3.4",
    "prettier-plugin-qingkuai": "^1.0.26",
    "rimraf": "^6.1.3",
    "rollup": "^4.53.3",
    "rollup-plugin-esbuild": "^6.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "ui",
    "framework",
    "reactive",
    "compiler",
    "templates",
    "component",
    "typescript",
    "performance"
  ],
  "description": "A lighteight(Qing) and fast(Kuai) front end framework, it will make you development work easier(QingKuai)."
}
