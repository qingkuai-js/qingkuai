{
  "printWidth": 100,
  "semi": false,
  "tabWidth": 4,
  "arrowParens": "avoid",
  "trailingComma": "none",
  "overrides": [
    {
      "files": [".*rc", "*.json"],
      "options": {
        "tabWidth": 2
      }
    },
    {
      "files": "regular.ts",
      "options": {
        "printWidth": 200
      }
    }
  ]
}
